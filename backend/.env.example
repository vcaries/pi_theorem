# Pi-Scope backend configuration (copy to `.env` and adjust as needed).
# All variables are prefixed with PISCOPE_.

# Verbose logging and FastAPI debug behaviour.
PISCOPE_DEBUG=false

# Root log level: DEBUG | INFO | WARNING | ERROR
PISCOPE_LOG_LEVEL=INFO

# Origins allowed to call the API from a browser (JSON array).
PISCOPE_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
